# ════════════════════════════════════════
# 市民服務平台管理後台 — 環境變數範本
# 複製此檔案為 .env.local 並填入實際值
# ════════════════════════════════════════

# ── Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_CASES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 政績版額外資料庫（純透明版不需要）
NOTION_DB_CONFIG=
NOTION_DB_INSPECTIONS=
NOTION_DB_INTERPELLATIONS=
NOTION_DB_PROPOSALS=

# ── NextAuth
NEXTAUTH_URL=https://your-admin.vercel.app
NEXTAUTH_SECRET=your-random-secret-here-min-32-chars

# ── Google OAuth（啟用 Google SSO 才需要）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── n8n
N8N_BASE_URL=https://drwu.zeabur.app
N8N_PREFIX=transparentcafe
N8N_NOTIFY_URL=https://drwu.zeabur.app/webhook/transparentcafe/notify

# ── LINE
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=
LINE_GROUP_ID=

# ── 系統模式
SYSTEM_MODE=transparent
# transparent = 純透明版
# achievement = 政績版（曾咨耀型）

# ── Super Admin（首次部署時建立）
SUPER_ADMIN_EMAIL=your@email.com
SUPER_ADMIN_PASSWORD=your-secure-password
